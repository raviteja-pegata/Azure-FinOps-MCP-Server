# ── Required ──────────────────────────────────────────────────────────────────
# Comma-separated subscription IDs the server is allowed to query.
AZURE_ALLOWED_SUBSCRIPTIONS=sub-id-1,sub-id-2,sub-id-3

# The subscription used when a tool is called without an explicit subscription_id.
# Must also appear in AZURE_ALLOWED_SUBSCRIPTIONS.
AZURE_DEFAULT_SUBSCRIPTION=sub-id-1

# ── Optional ──────────────────────────────────────────────────────────────────
# Tenant ID (only needed if DefaultAzureCredential can't infer it)
# AZURE_TENANT_ID=

# Cache TTL in seconds for expensive Cost Management queries (default: 900 = 15 min)
FINOPS_CACHE_TTL_SECONDS=900

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
